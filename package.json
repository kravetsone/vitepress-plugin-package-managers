{
  "name": "vitepress-plugin-package-managers",
  "version": "0.2.1",
  "description": "Display package manager commands with synced, persistent tabs for VitePress",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./client": "./src/client.ts",
    "./icons": "./src/icons.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external markdown-it",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "peerDependencies": {
    "vitepress": ">=1.0.0",
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.0",
    "vue": "^3.5.0"
  },
  "keywords": [
    "vitepress",
    "vitepress-plugin",
    "package-manager",
    "npm",
    "yarn",
    "pnpm",
    "bun",
    "deno"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kravetsone/vitepress-plugin-package-managers"
  }
}
